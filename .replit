modules = ["nodejs-20", "web", "bash", "python-3.11"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
API_PORT = "3001"
FRONTEND_PORT = "5001"
PREVIEW_PROXY_PORT = "5000"
VITE_TARGET_PORT = "5001"

[workflows]
runButton = "Start application"

# Single fresh-import workflow.
# Do not add a separate API workflow or a separate Vite workflow.
# scripts/replit-start.sh starts:
#   5000 = instant Replit preview proxy / webview
#   5001 = Vite frontend behind the proxy
#   3001 = Express/API server
[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/replit-start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 5002
externalPort = 5173

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 25876
externalPort = 3000

[[ports]]
localPort = 25877
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
# Production/autoscale serving: API on 3001, built frontend preview on 5000, /api proxied to 3001.
run = ["sh", "-c", "PORT=3001 API_PORT=3001 node --enable-source-maps artifacts/api-server/dist/index.mjs & PORT=5000 FRONTEND_PORT=5000 API_PORT=3001 pnpm --filter @workspace/candy-crackzzz run serve"]
# Only push DB schema when DATABASE_URL exists. The app can fall back to file storage when no database is configured.
build = ["sh", "-c", "pnpm install --frozen-lockfile && if [ -n \"$DATABASE_URL\" ]; then pnpm --filter @workspace/db run push; else echo 'DATABASE_URL not set; skipping database push and using file storage fallback.'; fi && PORT=3001 API_PORT=3001 pnpm --filter @workspace/api-server run build && PORT=5000 FRONTEND_PORT=5000 API_PORT=3001 pnpm --filter @workspace/candy-crackzzz run build"]
