modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "1234321"
PORT = "3001"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm --filter @workspace/api-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 API_PORT=3001 pnpm --filter @workspace/candy-crackzzz run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 25876
externalPort = 3000

[[ports]]
localPort = 25877
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "node --enable-source-maps artifacts/api-server/dist/index.mjs"]
build = ["sh", "-c", "pnpm install --frozen-lockfile && if [ -n \"$DATABASE_URL\" ]; then pnpm --filter @workspace/db run push; else echo \"No DATABASE_URL found, skipping database push and using file storage fallback\"; fi && pnpm --filter @workspace/candy-crackzzz run build && pnpm --filter @workspace/api-server run build"]
