# Replit root configuration for Candy CrackZZZ
# Keep this file at the repository/workspace root. Replit publishing looks for:
# /home/runner/workspace/.replit

modules = ["nodejs-20", "web", "bash"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
# Public/non-secret runtime defaults only. Put real passwords and keys in Replit Secrets.
PORT = "3001"
API_PORT = "3001"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm --filter @workspace/api-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 API_PORT=3001 pnpm --filter @workspace/candy-crackzzz run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 25876
externalPort = 3000

[[ports]]
localPort = 25877
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
# API server runs on 3001. Vite preview serves the built frontend on 5000 and proxies /api to 3001.
run = ["sh", "-c", "PORT=3001 node --enable-source-maps artifacts/api-server/dist/index.mjs & PORT=5000 API_PORT=3001 pnpm --filter @workspace/candy-crackzzz run serve"]
# Only push DB schema when DATABASE_URL exists. The app can fall back to file storage when no database is configured.
build = ["sh", "-c", "pnpm install --frozen-lockfile && if [ -n \"$DATABASE_URL\" ]; then pnpm --filter @workspace/db run push; else echo 'DATABASE_URL not set; skipping database push and using file storage fallback.'; fi && PORT=3001 pnpm --filter @workspace/api-server run build && PORT=5000 API_PORT=3001 pnpm --filter @workspace/candy-crackzzz run build"]
